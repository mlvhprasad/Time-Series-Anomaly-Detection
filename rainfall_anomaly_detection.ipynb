import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import IsolationForest

# ==========================
# LOAD DATASET
# ==========================

df = pd.read_csv("rainfall.csv")

print("Dataset Shape:", df.shape)
print("\nFirst 5 Rows:")
print(df.head())

print("\nMissing Values:")
print(df.isnull().sum())

# Fill missing values
df = df.fillna(0)

# ==========================
# CONVERT WIDE FORMAT TO LONG FORMAT
# ==========================

day_cols = df.columns[3:]

long_df = df.melt(
    id_vars=["state", "district", "month"],
    value_vars=day_cols,
    var_name="day",
    value_name="rainfall"
)

print("\nTransformed Dataset Shape:", long_df.shape)

# ==========================
# BASIC EDA
# ==========================

print("\nSummary Statistics:")
print(long_df["rainfall"].describe())

# Rainfall Distribution
plt.figure(figsize=(8,5))
sns.histplot(long_df["rainfall"], bins=50)
plt.title("Rainfall Distribution")
plt.xlabel("Rainfall")
plt.ylabel("Frequency")
plt.show()

# State-wise Average Rainfall
state_rainfall = (
    long_df.groupby("state")["rainfall"]
    .mean()
    .sort_values(ascending=False)
    .head(10)
)

plt.figure(figsize=(10,5))
state_rainfall.plot(kind="bar")
plt.title("Top 10 States by Average Rainfall")
plt.ylabel("Average Rainfall")
plt.show()

# Monthly Trend
monthly_rainfall = (
    long_df.groupby("month")["rainfall"]
    .mean()
)

plt.figure(figsize=(10,5))
monthly_rainfall.plot(marker='o')
plt.title("Monthly Average Rainfall")
plt.xlabel("Month")
plt.ylabel("Average Rainfall")
plt.show()

# ==========================
# FEATURE ENGINEERING
# ==========================

long_df = long_df.sort_values(
    ["state", "district", "month"]
)

long_df["rolling_mean_7"] = (
    long_df["rainfall"]
    .rolling(window=7)
    .mean()
)

long_df["rolling_std_7"] = (
    long_df["rainfall"]
    .rolling(window=7)
    .std()
)

long_df["rainfall_change"] = (
    long_df["rainfall"]
    .pct_change()
)

long_df = long_df.fillna(0)

# ==========================
# FEATURE MATRIX
# ==========================

features = [
    "rainfall",
    "rolling_mean_7",
    "rolling_std_7",
    "rainfall_change"
]

X = long_df[features]

# ==========================
# SCALING
# ==========================

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# ==========================
# HYPERPARAMETER EXPERIMENTS
# ==========================

print("\nIsolation Forest Experiments")

for contamination in [0.01, 0.03, 0.05, 0.10]:

    model = IsolationForest(
        contamination=contamination,
        random_state=42
    )

    predictions = model.fit_predict(X_scaled)

    anomaly_count = (predictions == -1).sum()

    print(
        f"Contamination={contamination} "
        f"| Anomalies={anomaly_count}"
    )

# ==========================
# FINAL MODEL
# ==========================

model = IsolationForest(
    contamination=0.05,
    random_state=42
)

long_df["anomaly"] = model.fit_predict(X_scaled)

long_df["anomaly"] = long_df["anomaly"].map({
    1: 0,
    -1: 1
})

print("\nDetected Anomalies:")
print(long_df["anomaly"].value_counts())

# ==========================
# VISUALIZATION
# ==========================

plt.figure(figsize=(14,6))

plt.plot(
    long_df.index,
    long_df["rainfall"],
    label="Rainfall"
)

anomalies = long_df[
    long_df["anomaly"] == 1
]

plt.scatter(
    anomalies.index,
    anomalies["rainfall"],
    label="Anomaly"
)

plt.title("Rainfall Anomaly Detection")
plt.xlabel("Observation")
plt.ylabel("Rainfall")
plt.legend()
plt.show()

# ==========================
# SAVE RESULTS
# ==========================

long_df.to_csv(
    "detected_anomalies.csv",
    index=False
)

print("\nResults saved as detected_anomalies.csv")